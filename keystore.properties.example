# Release signing config for auto-silent-timer.
#
# Copy this file to "keystore.properties" (which is gitignored) and fill in real values.
# The .jks/.keystore file itself is also gitignored, so keep a safe backup of it.
#
#   storeFile   - path to your keystore. Relative paths resolve from the repo root;
#                 absolute paths also work. (Keystores in the repo are gitignored.)
#   storePassword - the keystore password
#   keyAlias    - the key alias inside the keystore
#   keyPassword - the password for that key (often same as storePassword)
#
# ALTERNATIVE 1 (other machines / CI): instead of this file, set env vars and the build will
# use them automatically -- no secret file on disk:
#   ASTIMER_KEYSTORE_FILE      (absolute path to the .jks)
#   ASTIMER_KEYSTORE_PASSWORD
#   ASTIMER_KEY_ALIAS
#   ASTIMER_KEY_PASSWORD
#
# ALTERNATIVE 2 (encrypted-on-Drive workflow):
#   1. `npm run encrypt-keystore`  -> writes keystore/release-signing.enc (safe to keep on
#      Drive / commit). You'll choose a passphrase; keep it in your password manager.
#   2. On each machine: `npm run decrypt-keystore` -> unpacks the keystore + credentials to a
#      local, non-synced folder (~/.astimer-keystore), which Gradle reads automatically.
#   Then `npm run build-release-apk` signs the build. The signing resolution order is:
#   keystore.properties (this file) -> ASTIMER_* env vars -> ~/.astimer-keystore/keystore.properties

storeFile=keystore/auto-silent-timer-release.jks
storePassword=CHANGE_ME
keyAlias=CHANGE_ME
keyPassword=CHANGE_ME
