<?xml version="1.0" encoding="utf-8"?>
<!-- Strings owned by the onboarding UI (Phase 2b). Kept separate from the
     shared strings.xml so the engine/UI phases don't collide. -->
<resources>
    <!-- Shown after monitoring starts while POST_NOTIFICATIONS and/or exact-alarm
         are still missing: monitoring is allowed, but reliability may suffer. -->
    <string name="msg_recommended_permissions">Monitoring started. Notifications and exact alarm are recommended for reliable auto-restore.</string>
    <!-- Shown when a settings deep-link cannot be opened on this device. -->
    <string name="msg_settings_unavailable">Couldn\'t open that settings screen on this device.</string>
    <!-- Status shown when monitoring is enabled (the default/intent) but the
         required overlay + DND permissions are not both granted yet. -->
    <string name="status_monitoring_pending">Monitoring will start automatically once the required permissions are granted.</string>
</resources>
